# ─────────────────────────────────────────────────────────────
# Blackstar — secret credentials
# Copy this file to ".env" and fill in your real values.
# ".env" is gitignored; never commit real secrets.
# Non-secret settings (owner name/number, bot name, IDs, etc.)
# stay in config.js.
# ─────────────────────────────────────────────────────────────

# SightEngine (NSFW moderation) — https://sightengine.com
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Google Gemini API key
GEMINI_API_KEY=

# Jules API key
JULES_API_KEY=
